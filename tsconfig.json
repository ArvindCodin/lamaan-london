{
  "include": ["app/**/*", "server.mjs"],
  "exclude": ["node_modules", "build", "dist"],
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "allowJs": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node", "vite/client"],
    "paths": {
      "~/*": ["./app/*"]
    }
  }
}
