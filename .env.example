# Shopify Storefront API credentials
# Get these from: Shopify Admin → Settings → Apps → Develop apps → Your app → API credentials
PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Session secret — any random string (32+ characters)
SESSION_SECRET=your-random-session-secret-here
